# ── Sevam Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sevam?retryWrites=true&w=majority

# The database name inside your Atlas cluster
DATABASE_NAME=sevam

# Groq API key (for LLM inference)
GROQ_API_KEY=your_groq_key_here
